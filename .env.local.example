# Copy this file to .env.local and paste your real values.
# NEVER commit .env.local – it is gitignored.
#
# Get Supabase values from: Project Settings → API
# - NEXT_PUBLIC_SUPABASE_URL: project URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY: anon public key
# - SUPABASE_SERVICE_ROLE_KEY: service_role key (server-only, never expose to client)
#
# Restart the dev server after changing env vars: npm run dev

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SMTP_USER=
SMTP_PASS=
ORDERS_TO_EMAILS=
# Admin session (recommended). If set: "Exit admin" clears session and next visit requires re-login.
# Also required for PDF downloads to work (fetch with credentials).
ADMIN_SESSION_SECRET=
